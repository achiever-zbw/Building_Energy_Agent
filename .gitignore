# =============================================================================
# 仅跟踪 backend/（及本文件）；仓库根下其余目录一律忽略
# =============================================================================
*
!.gitignore
!/backend/
!/backend/**

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/
*.egg
.venv/
venv/
ENV/

# -----------------------------------------------------------------------------
# 环境变量与密钥（勿提交）
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# 测试 / 类型 / 缓存
# -----------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# -----------------------------------------------------------------------------
# IDE / 系统
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# -----------------------------------------------------------------------------
# backend 内运行时状态（会话流水号等）
# -----------------------------------------------------------------------------
backend/workspace/memory/history.jsonl
backend/workspace/memory/.history_jsonl_cursor

# =============================================================================
# 历史：曾单独忽略的 vendored/实验目录（已被「只保留 backend」覆盖）
# =============================================================================
/RAG-Anything
